# Application
APP_NAME=Knowledge Chatbot
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_PREFIX=/api/v1
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=change-me-to-a-long-random-secret-in-production
INITIAL_ADMIN_EMAIL=admin@example.com
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_secret
POSTGRES_DB=chatbot
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@localhost:5432/chatbot

# Redis / workers
REDIS_URL=redis://localhost:6379/0
ARQ_REDIS_URL=redis://localhost:6379/0

# Vector store
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./storage/chroma

# File storage
STORAGE_PATH=./storage/uploads
TEMP_PATH=./storage/temp
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,csv,md,markdown,ppt,pptx,xls,xlsx,json,html,htm,png,jpg,jpeg,webp,tiff,zip

# LLM — OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM — Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Default provider selection (openai | ollama)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_EMBEDDING_PROVIDER=ollama

# RAG defaults
RAG_TOP_K=8
RAG_MMR_LAMBDA=0.5
RAG_SIMILARITY_THRESHOLD=0.35
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_HYBRID_ALPHA=0.7
EMBEDDING_BATCH_SIZE=32
RAG_ALLOW_GENERAL_KNOWLEDGE=false

# Email / SMTP (Mailpit locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@chatbot.local
SMTP_TLS=false
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# OCR
TESSERACT_CMD=tesseract

# Docker (optional overrides)
# VITE_API_BASE_URL=http://localhost:8000/api/v1
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# NGINX_PORT=80
